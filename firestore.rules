rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(data) {
      return isSignedIn() && data.userId == request.auth.uid;
    }

    function incomingIsOwner() {
      return isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    function keepsOwnership() {
      // Para update: la propiedad debe seguir siendo del mismo usuario (no transferible).
      return isOwner(resource.data) && request.resource.data.userId == resource.data.userId;
    }

    function esStringCorto(v, maxLen) {
      return v is string && v.size() <= maxLen;
    }

    function esFechaValidaOpcional(v) {
      // Acepta null o string de fecha (ISO corta o completa).
      return v == null || (v is string && v.size() <= 40);
    }

    // --- Perfil de usuario ---
    match /usuarios/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // --- Tareas pendientes ---
    match /tareas/{tareaId} {
      allow read: if isOwner(resource.data);

      allow create: if incomingIsOwner()
        && esStringCorto(request.resource.data.titulo, 500)
        && request.resource.data.titulo.size() > 0
        && (!('carpeta' in request.resource.data)
            || request.resource.data.carpeta == null
            || esStringCorto(request.resource.data.carpeta, 100))
        && (!('fechaLimite' in request.resource.data)
            || esFechaValidaOpcional(request.resource.data.fechaLimite));

      allow update: if keepsOwnership()
        && esStringCorto(request.resource.data.titulo, 500)
        && request.resource.data.titulo.size() > 0
        && (!('carpeta' in request.resource.data)
            || request.resource.data.carpeta == null
            || esStringCorto(request.resource.data.carpeta, 100))
        && (!('fechaLimite' in request.resource.data)
            || esFechaValidaOpcional(request.resource.data.fechaLimite));

      allow delete: if isOwner(resource.data);
    }

    // --- Tareas completadas ---
    match /completadas/{tareaId} {
      allow read: if isOwner(resource.data);

      allow create: if incomingIsOwner()
        && esStringCorto(request.resource.data.titulo, 500)
        && request.resource.data.titulo.size() > 0
        && (!('carpeta' in request.resource.data)
            || request.resource.data.carpeta == null
            || esStringCorto(request.resource.data.carpeta, 100))
        && (!('fechaLimite' in request.resource.data)
            || esFechaValidaOpcional(request.resource.data.fechaLimite));

      allow update: if keepsOwnership()
        && esStringCorto(request.resource.data.titulo, 500)
        && request.resource.data.titulo.size() > 0;

      allow delete: if isOwner(resource.data);
    }

    // --- Carpetas ---
    match /carpetas/{carpetaId} {
      allow read: if isOwner(resource.data);

      allow create: if incomingIsOwner()
        && esStringCorto(request.resource.data.nombre, 100)
        && request.resource.data.nombre.size() > 0;

      allow update: if keepsOwnership()
        && esStringCorto(request.resource.data.nombre, 100)
        && request.resource.data.nombre.size() > 0;

      allow delete: if isOwner(resource.data);
    }
  }
}
